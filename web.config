<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <httpProtocol>
      <customHeaders>
        <!-- The script-src hash allows exactly one inline script: the
             "window.CROSSCANVAS_EMBED = true;" flag the PingCanvas kiosk
             build injects into kiosk.html. Without it, serving kiosk.html
             under this config silently boots the wall in editor mode
             (autosave prompts on an unattended screen). Keep the hash in
             sync with the injected string in PingCanvas's
             tools/sync-from-crosscanvas.ps1 and docker/build-web.ps1. -->
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'sha256-M3xh1E6BobQqrgZB9DFnlbp/+XByW49Qhf+08vqZtL8='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
      </customHeaders>
    </httpProtocol>
    <staticContent>
      <remove fileExtension=".js" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
      <!-- Serve boards as JSON so the ?board= URL parameter can fetch them.
           (.netdraw = the pre-rename extension, honored forever.) -->
      <remove fileExtension=".xcanvas" />
      <mimeMap fileExtension=".xcanvas" mimeType="application/json" />
      <remove fileExtension=".netdraw" />
      <mimeMap fileExtension=".netdraw" mimeType="application/json" />
    </staticContent>
  </system.webServer>
</configuration>
